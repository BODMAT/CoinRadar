# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Comma-separated allowed origins for CORS (frontend apps)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://bodmat.github.io

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/CoinRadar?schema=public

# JWT
# Use long random strings in real environments
JWT_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=30
# Cookie SameSite policy: lax | strict | none
# For cross-domain frontend/backend in production usually use "none" (requires HTTPS/secure cookies).
# For local same-site development usually "lax" is enough.
COOKIE_SAME_SITE=lax

# Google OAuth
# Create OAuth 2.0 Web Client in Google Cloud Console
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
